{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path aliases — mirror vite.config.ts aliases for type resolution */
    "paths": {
      "@components/*": ["./node_modules/srcl/components/*"],
      "@common/*": ["./node_modules/srcl/common/*"],
      "@modules/*": ["./node_modules/srcl/modules/*"]
    },
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",

    /* Linting */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
  /* Note: skipLibCheck only skips .d.ts files, not raw .ts source in node_modules/srcl.
     Vite still bundles everything correctly; only tsc type-checking is affected.
     The build uses vite (no tsc emit), so TS errors in node_modules/srcl/common don't block runtime. */
}
