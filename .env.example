# Emporia relay — copy to profile .env or emporia/.env. Installer resolves keys from parent dirs + config.yaml.
EMPORIA_GUARDRAILS_MODE=enforce
# Set by installer when NVIDIA_API_KEY is available (profile, parent .env, config, or prompt):
# EMPORIA_NEMO_GUARDRAILS_ENABLED=1
# NVIDIA_API_KEY=nvapi-...
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PROFILE_ID=profile_...